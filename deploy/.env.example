# ─────────────────────────────────────────────────
# BRATAN MUSIC — Environment Variables
# Copy to .env and fill in the values
# ⚠️ NEVER commit .env to git (repo is public!)
# ─────────────────────────────────────────────────

# ── Domain ──────────────────────────────────────
DOMAIN=bratan-music.eu.cc
APP_URL=https://bratan-music.eu.cc

# ── Postgres ────────────────────────────────────
POSTGRES_PASSWORD=          # generate: openssl rand -hex 24

# ── MinIO (S3-compatible storage) ───────────────
MINIO_ACCESS_KEY=           # generate: openssl rand -hex 16
MINIO_SECRET_KEY=           # generate: openssl rand -hex 32

# ── Auth secrets ────────────────────────────────
JWT_SECRET=                 # generate: openssl rand -hex 32
JWT_REFRESH_SECRET=         # generate: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=     # generate: openssl rand -hex 32

# ── Telegram ────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=bratan_music_bot
TELEGRAM_ADMIN_IDS=         # comma-separated Telegram user IDs
TELEGRAM_WEBHOOK_SECRET=    # generate: openssl rand -hex 32

# ── Email (Brevo) ──────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply.bratanmusic@gmail.com
BREVO_SENDER_NAME=BRATAN MUSIC

# ── Yandex AI (recommendations) ────────────────
YANDEX_API_TOKEN=
YANDEX_FOLDER_ID=
YANDEX_MODEL_URI=

# ── Tidal (stored in DB, not env — leave empty) ─
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_SESSION_TOKEN=
