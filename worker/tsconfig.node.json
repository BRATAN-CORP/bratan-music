{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "jsx": "react-jsx",
    "types": ["node", "@cloudflare/workers-types"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/do/ChatRoomDO.ts"
  ]
}
