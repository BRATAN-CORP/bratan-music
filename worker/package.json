{
  "name": "bratan-music-worker",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "wrangler dev",
    "dev:node": "tsx watch src/node-entry.ts",
    "build:node": "tsc -p tsconfig.node.json",
    "start:node": "node dist/node-entry.js",
    "deploy": "wrangler deploy",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "wrangler d1 execute bratan-music-db --local --file=src/db/migrations/0001_init.sql"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "esbuild": "^0.28.0",
    "hono": "^4.12.16",
    "ioredis": "^5.6.1",
    "minio": "^8.0.5",
    "pg": "^8.16.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250411.0",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.11.11",
    "@types/ws": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
